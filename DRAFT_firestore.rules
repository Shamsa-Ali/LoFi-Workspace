rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Note Validation
    function isValidNote(data) {
      return data.keys().hasAll(['title', 'content', 'userId', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 5 &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 10000 &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    // Todo Validation
    function isValidTodo(data) {
      return data.keys().hasAll(['text', 'completed', 'userId', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.text is string && data.text.size() <= 500 &&
             data.completed is bool &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    // Settings Validation
    function isValidSettings(data) {
      return data.keys().hasAll(['userId', 'theme', 'volume', 'pomodoroWorkMinutes', 'pomodoroBreakMinutes']) &&
             data.userId == request.auth.uid &&
             data.theme is string && data.volume is number;
    }

    match /notes/{noteId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidNote(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && 
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().userId && // Immutable createdAt (wait, existing() check needs to be precise)
                      isValidNote(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'updatedAt']);
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /todos/{todoId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidTodo(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) &&
                      incoming().userId == existing().userId &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['text', 'completed']);
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /settings/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow write: if isSignedIn() && isOwner(userId) && isValidSettings(incoming());
    }
  }
}
